<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<style>
  *{box-sizing:border-box;margin:0;padding:0;}
  
  body {
    background: #f0ead8; /* Your site's cream background */
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 20px;
    overflow: hidden;
  }

  /* Your scanline paper texture overlay */
  body::before {
    content:'';
    position:fixed;
    inset:0;
    background-image: repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.012) 2px,rgba(0,0,0,0.012) 4px);
    pointer-events:none;
    z-index: 10;
  }

  .container {
    position: relative;
    max-width: 100%;
    max-height: 90vh;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  img {
    max-width: 100%;
    max-height: 85vh;
    height: auto;
    width: auto;
    display: block;
    /* Adds a retro sharp dark border to match your zine style */
    border: 4px solid #111; 
    box-shadow: 6px 6px 0px #e8001a;
  }

  /* Quick back link so people don't get stuck */
  .back-link {
    position: fixed;
    bottom: 20px;
    font-family: monospace;
    font-size: 11px;
    text-decoration: none;
    color: #111;
    border-bottom: 1px dotted #111;
    z-index: 20;
  }
  .back-link:hover {
    color: #e8001a;
    border-bottom-color: #e8001a;
  }
</style>
</head>
<body>

<div class="container">
  <img src="bilimadami.jpg" alt="Gallery Image">
</div>

<a href="index.html" class="back-link">// BACK TO PORTAL</a>

</body>
</html>
